{
  "name": "openreveal",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, consent-based spectator-phone mentalism PWA.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @openreveal/shared build && pnpm -r --parallel --if-present dev",
    "build": "pnpm -r --if-present build",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "audit": "pnpm audit --audit-level moderate",
    "maintenance:cleanup": "pnpm --filter @openreveal/api maintenance:cleanup",
    "record:location-celebrity": "node scripts/record-location-celebrity.mjs",
    "record:showcase": "node scripts/record-showcase.mjs",
    "release:scan": "node scripts/release-artifact-scan.mjs",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "cloudrun:deploy": "./scripts/cloud-run-deploy.sh",
    "cloudrun:preflight": "node scripts/cloud-run-preflight.mjs",
    "smoke:deploy": "node scripts/deployment-smoke.mjs",
    "security:probe": "node scripts/security-probe.mjs",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --workspace-concurrency=1 --if-present test",
    "test:e2e": "playwright test",
    "test:latency": "playwright test --config playwright.latency.config.ts",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0",
    "ws": "^8.18.3"
  }
}
